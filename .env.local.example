# Supabase — https://app.supabase.com/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# NVIDIA NIM — https://build.nvidia.com (for LLaMA 3.3 summarization)
# Get key at: https://build.nvidia.com → any model → Get API Key
NVIDIA_NIM_API_KEY=nvapi-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Deepgram — https://console.deepgram.com (for Transcription + Speaker Diarization)
# Get a free key at: https://console.deepgram.com
DEEPGRAM_API_KEY=your-deepgram-api-key

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
